# PostgreSQL (Railway ou local) — formato:
# postgresql://usuario:senha@host:porta/database
DATABASE_URL=

PORT=4000
FRONTEND_URL=http://localhost:3000
# em produção: domínio pai compartilhado entre frontend e backend, com ponto
# na frente, para o cookie de sessão valer nos dois subdomínios (ex: .narrativasdecoloniais.com.br)
COOKIE_DOMAIN=

JWT_ACCESS_SECRET=troque-por-um-segredo-forte
JWT_REFRESH_SECRET=troque-por-outro-segredo-forte
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# E-mail via Resend (API HTTP — SMTP é bloqueado pelo Railway)
# dev: deixe em branco para usar o Ethereal e logar o link de preview no console
RESEND_API_KEY=
EMAIL_FROM="Narrativas <nao-responda@narrativasdecoloniais.com.br>"
